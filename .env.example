# ─── Firebase (frontend) ─────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# ─── Cloudinary (upload de fotos, comprovantes e PDFs de contrato) ───────────
# Necessário para: fotos de imóveis/veículos, comprovantes de pagamento,
# documentos de KYC do afiliado e o anexo de contrato importado (PDF).
# Sem estas variáveis, qualquer upload falha com "Cloudinary não configurado".
# O upload preset PRECISA ser "unsigned" (Cloudinary > Settings > Upload >
# Upload presets > Signing Mode: Unsigned), pois o upload sai direto do
# navegador, sem passar pelo backend.
VITE_CLOUDINARY_CLOUD_NAME=seu-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=seu-upload-preset-unsigned

# ─── EmailJS (envio do link de assinatura para testemunhas) ──────────────────
# Painel EmailJS > Account (Public Key), Email Services e Email Templates.
VITE_EMAILJS_PUBLIC_KEY=sua-public-key
VITE_EMAILJS_SERVICE_ID=seu-service-id
VITE_EMAILJS_TEMPLATE_WITNESS=seu-template-id

# ─── Firebase Admin SDK (backend / Vercel API) ────────────────────────────────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Asaas (cobranças e split de pagamento) ───────────────────────────────────
# true = usa api-sandbox.asaas.com (ambiente de testes); false = produção
ASAAS_USE_SANDBOX=true
# Chave de API principal — Painel Asaas > Integrações > Chaves de API
ASAAS_API_KEY_SANDBOX=$aact_hmlg_xxxxxxxxxxxxxxxxxxxx
ASAAS_API_KEY=$aact_prod_xxxxxxxxxxxxxxxxxxxx
# Token enviado pela Asaas no header asaas-access-token de cada webhook —
# configure o mesmo valor ao registrar o webhook no painel Asaas
ASAAS_WEBHOOK_TOKEN=gere_um_token_forte_aqui

# ─── WhatsApp automático (Evolution API) ─────────────────────────────────────
# Suba o Evolution API no Railway usando docker-compose.evolution.yml
# Depois do deploy, copie a URL gerada pelo Railway aqui.
EVOLUTION_API_URL=https://seu-servico.up.railway.app
# Chave de autenticação — a mesma definida no docker-compose.evolution.yml
EVOLUTION_API_KEY=trocar_esta_chave_forte
# Nome da instância criada no Evolution API (padrão: alugapro)
EVOLUTION_INSTANCE=alugapro

# ─── Resend (e-mail marketing / disparos) ────────────────────────────────────
# Crie a conta em resend.com, verifique o domínio alugapro.tech (adicione os
# registros SPF/DKIM no DNS) e gere a API key em Resend > API Keys.
# Sem esta key, /api/send-campaign responde 503 (envio desativado).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Remetente — precisa ser de um domínio VERIFICADO no Resend. Endereço humanizado
# que também recebe respostas (domínio com receiving ativo) → respostas caem no CRM.
RESEND_FROM=contato@alugapro.tech
# Assinatura dos webhooks do Resend (aberturas/cliques/bounces e respostas).
# Resend > Webhooks > (seu endpoint /api/resend-webhook) > Signing Secret.
# Sem ela, /api/resend-webhook recusa os eventos (503) por segurança.
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ─── Cron e segurança interna ────────────────────────────────────────────────
# Vercel injeta este segredo automaticamente no header do cron.
# Gere com: openssl rand -hex 32
CRON_SECRET=gere_um_segredo_forte_aqui
# Chave interna para chamadas server-to-server (ex: gestor → whatsapp-notify)
INTERNAL_API_KEY=gere_outra_chave_forte_aqui
# Mesma chave, exposta ao frontend (usada pelas páginas internas de notificação)
VITE_INTERNAL_API_KEY=mesmo_valor_de_INTERNAL_API_KEY

# ─── URL pública da aplicação ────────────────────────────────────────────────
# Usada pelo checkout da Asaas para montar a URL de retorno após o pagamento.
VITE_APP_URL=https://alugapro.tech.br
