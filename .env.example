# ─── Firebase (frontend) ─────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# ─── Firebase Admin SDK (backend / Vercel API) ────────────────────────────────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Asaas (cobranças e split de pagamento) ───────────────────────────────────
# true = usa api-sandbox.asaas.com (ambiente de testes); false = produção
ASAAS_USE_SANDBOX=true
# Chave de API principal — Painel Asaas > Integrações > Chaves de API
ASAAS_API_KEY_SANDBOX=$aact_hmlg_xxxxxxxxxxxxxxxxxxxx
ASAAS_API_KEY=$aact_prod_xxxxxxxxxxxxxxxxxxxx
# Token enviado pela Asaas no header asaas-access-token de cada webhook —
# configure o mesmo valor ao registrar o webhook no painel Asaas
ASAAS_WEBHOOK_TOKEN=gere_um_token_forte_aqui

# ─── Mercado Pago (legado — em migração para a Asaas) ────────────────────────
MP_ACCESS_TOKEN_PROD=APP_USR-xxxxxxxxxxxxxxxxxxxx
MP_ACCESS_TOKEN_TEST=TEST-xxxxxxxxxxxxxxxxxxxx
MP_USE_TEST=false
MP_WEBHOOK_SECRET_PROD=your-webhook-secret
MP_WEBHOOK_SECRET_TEST=your-webhook-secret

# ─── WhatsApp automático (Evolution API) ─────────────────────────────────────
# Suba o Evolution API no Railway usando docker-compose.evolution.yml
# Depois do deploy, copie a URL gerada pelo Railway aqui.
EVOLUTION_API_URL=https://seu-servico.up.railway.app
# Chave de autenticação — a mesma definida no docker-compose.evolution.yml
EVOLUTION_API_KEY=trocar_esta_chave_forte
# Nome da instância criada no Evolution API (padrão: alugapro)
EVOLUTION_INSTANCE=alugapro

# ─── Cron e segurança interna ────────────────────────────────────────────────
# Vercel injeta este segredo automaticamente no header do cron.
# Gere com: openssl rand -hex 32
CRON_SECRET=gere_um_segredo_forte_aqui
# Chave interna para chamadas server-to-server (ex: gestor → whatsapp-notify)
INTERNAL_API_KEY=gere_outra_chave_forte_aqui
# Mesma chave, exposta ao frontend (usada pelo /sistema e pelas páginas internas)
VITE_INTERNAL_API_KEY=mesmo_valor_de_INTERNAL_API_KEY

# ─── Sistema Comercial (/sistema) — inbox interno de prospecção via WhatsApp ──
# Time comercial do próprio AlugaPro (não é dado de empresa-cliente).
# Já tem padrão fixo no código ("alugapro-interno") — só defina aqui se
# quiser usar outro valor. Precisa bater com o que o código usa.
# SALES_COMPANY_ID=alugapro-interno
# Segredo da URL do webhook — gere com: openssl rand -hex 32
# Configure na Evolution API: POST /webhook/set/alugapro
# Body: { "url": "https://seuapp.vercel.app/api/whatsapp-webhook?key=ESSE_VALOR", "webhook_by_events": false, "events": ["MESSAGES_UPSERT"] }
WEBHOOK_SECRET=gere_outro_segredo_forte_aqui
