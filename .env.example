# ─── Firebase (frontend) ─────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# ─── Firebase Admin SDK (backend / Vercel API) ────────────────────────────────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Mercado Pago ─────────────────────────────────────────────────────────────
MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxx
MP_WEBHOOK_SECRET=your-webhook-secret

# ─── WhatsApp automático (Evolution API) ─────────────────────────────────────
# Suba o Evolution API no Railway usando docker-compose.evolution.yml
# Depois do deploy, copie a URL gerada pelo Railway aqui.
EVOLUTION_API_URL=https://seu-servico.up.railway.app
# Chave de autenticação — a mesma definida no docker-compose.evolution.yml
EVOLUTION_API_KEY=trocar_esta_chave_forte
# Nome da instância criada no Evolution API (padrão: alugapro)
EVOLUTION_INSTANCE=alugapro

# ─── Cron e segurança interna ────────────────────────────────────────────────
# Vercel injeta este segredo automaticamente no header do cron.
# Gere com: openssl rand -hex 32
CRON_SECRET=gere_um_segredo_forte_aqui
# Chave interna para chamadas server-to-server (ex: gestor → whatsapp-notify)
INTERNAL_API_KEY=gere_outra_chave_forte_aqui
