rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    // Empresa demo: dados de vitrine acessíveis sem autenticação (uso comercial)
    function isDemo() {
      return 'companyId' in resource.data && resource.data.companyId == 'alugapro-demo';
    }

    // Admins reais reconhecidos pelo e-mail do token (não dependem de doc em users/)
    function isAdminEmail() {
      return isAuthenticated() &&
        request.auth.token.email in ['rayansl0302@gmail.com', 'rayansl.dev@gmail.com'];
    }

    function userExists() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isRole(role) {
      return userExists() && getUserData().role == role;
    }

    function isAdmin() {
      return isAdminEmail() || isRole('admin');
    }

    function isGestor() {
      return isAdmin() || isRole('gestor');
    }

    function isProprietario() {
      return isGestor() || isRole('proprietario');
    }

    // Agentes comerciais (/sistema) — inbox compartilhado de prospecção
    function isComercial() {
      return isAdmin() || isRole('comercial');
    }

    function isInquilinoOf(tenantId) {
      return isAuthenticated() && request.auth.uid == tenantId;
    }

    // Inquilino vinculado ao registro em tenants/{tenantId} (nem sempre igual ao auth.uid)
    function isLinkedTenant(tenantId) {
      return userExists()
        && isRole('inquilino')
        && getUserData().tenantId == tenantId;
    }

    function sameCompany(companyId) {
      return isAdmin() || (userExists() && getUserData().companyId == companyId);
    }

    function inquilinoIsSharedExpenseParticipant() {
      let tid = getUserData().tenantId;
      return !('participantTenantIds' in resource.data)
        || (tid != null && tid in resource.data.participantTenantIds)
        || request.auth.uid in resource.data.participantTenantIds;
    }

    // Verifica se a assinatura da empresa permite escrita
    function subscriptionCanWrite(companyId) {
      let sub = get(/databases/$(database)/documents/subscriptions/$(companyId)).data;
      return sub.status == 'trialing' || sub.status == 'active';
    }

    // Verifica se a assinatura existe e permite leitura (tolerância em past_due/canceled)
    function subscriptionHasAccess(companyId) {
      return !exists(/databases/$(database)/documents/subscriptions/$(companyId)) ||
        get(/databases/$(database)/documents/subscriptions/$(companyId)).data.status in
          ['trialing', 'active', 'past_due', 'canceled'];
    }

    // Subscriptions
    match /subscriptions/{companyId} {
      allow read: if isAdmin() || sameCompany(companyId)
        || (isRole('afiliado')
            && exists(/databases/$(database)/documents/affiliateReferrals/$(companyId))
            && get(/databases/$(database)/documents/affiliateReferrals/$(companyId)).data.code == getUserData().referralCode);
      allow write: if isAdminEmail();
      allow create: if sameCompany(companyId) && isGestor();
    }

    // Affiliate Referrals — vincula uma empresa a um único código de afiliado,
    // pra sempre. Documento indexado pelo próprio companyId (uma indicação por
    // empresa) — só pode ser criado uma vez (update/delete sempre false) e só
    // enquanto a assinatura não estiver "active" (evita vincular um código
    // depois que a empresa já é cliente pagante; continua liberado em trial,
    // past_due, canceled ou expired — ou seja, também numa renovação).
    match /affiliateReferrals/{companyId} {
      allow read: if isAdmin()
        || sameCompany(companyId)
        || (isRole('afiliado') && getUserData().referralCode == resource.data.code);
      allow create: if isAuthenticated()
        && companyId == 'company_' + request.auth.uid
        && request.resource.data.companyId == companyId
        && request.resource.data.code is string
        && request.resource.data.code.size() > 0
        && (!exists(/databases/$(database)/documents/subscriptions/$(companyId))
            || get(/databases/$(database)/documents/subscriptions/$(companyId)).data.status != 'active');
      allow update, delete: if false;
    }

    // Companies
    match /companies/{companyId} {
      allow read: if companyId == 'alugapro-demo'
        || (isAuthenticated() &&
          (sameCompany(companyId) || companyId == 'company_' + request.auth.uid));
      allow create: if isAdmin()
        // Novo gestor criando sua própria empresa (companyId = company_{uid})
        || (isAuthenticated()
            && companyId == 'company_' + request.auth.uid
            && request.resource.data.ownerId == request.auth.uid);
      allow update: if isAdmin() && sameCompany(companyId);
      allow delete: if false; // never delete companies via client
    }

    // Users
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
      // Novo gestor: auto-registro sem convite (cria o próprio doc na primeira vez)
      allow create: if request.auth.uid == userId
        && request.resource.data.role == 'gestor'
        && request.resource.data.companyId == 'company_' + request.auth.uid
        && request.resource.data.active == true;
      // O usuário convidado materializa o próprio doc conforme o convite criado
      // pelo gestor — sem poder escolher empresa ou papel arbitrários.
      allow create, update: if request.auth.uid == userId
        && exists(/databases/$(database)/documents/userInvites/$(request.auth.token.email))
        && request.resource.data.role == get(/databases/$(database)/documents/userInvites/$(request.auth.token.email)).data.role
        && request.resource.data.companyId == get(/databases/$(database)/documents/userInvites/$(request.auth.token.email)).data.companyId;
      // O próprio usuário pode atualizar apenas dados de contato/verificação de
      // telefone do seu doc, sem alterar papel nem empresa.
      allow update: if request.auth.uid == userId
        && resource != null
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['phone', 'whatsapp', 'phoneVerified', 'phoneVerifiedAt',
                      'cpf', 'pixKey', 'documentPhotoUrl', 'documentSelfieUrl', 'kycSubmittedAt',
                      'address', 'monthlyIncome', 'asaasWalletId', 'updatedAt'])
        && request.resource.data.role == resource.data.role
        && request.resource.data.companyId == resource.data.companyId;
    }

    // Convites de acesso (criados pelo gestor; lidos só pelo próprio convidado)
    match /userInvites/{email} {
      allow read: if isAuthenticated() && request.auth.token.email == email;
      allow create, update: if isGestor();
      allow delete: if isAdmin();
    }

    // Properties
    match /properties/{propertyId} {
      allow read: if isDemo()
        || (isAuthenticated() && sameCompany(resource.data.companyId)
          && (isAdminEmail() || subscriptionHasAccess(resource.data.companyId)));
      allow create, update: if isGestor() && sameCompany(request.resource.data.companyId)
        && (isAdminEmail() || subscriptionCanWrite(request.resource.data.companyId));
      allow delete: if isAdmin();
    }

    // Vehicles
    match /vehicles/{vehicleId} {
      allow read: if isDemo()
        || (isAuthenticated() && sameCompany(resource.data.companyId)
          && (isAdminEmail() || subscriptionHasAccess(resource.data.companyId)));
      allow create, update: if isGestor() && sameCompany(request.resource.data.companyId)
        && (isAdminEmail() || subscriptionCanWrite(request.resource.data.companyId));
      allow delete: if isAdmin();
    }

    // Equipments
    match /equipments/{equipmentId} {
      allow read: if isDemo()
        || (isAuthenticated() && sameCompany(resource.data.companyId)
          && (isAdminEmail() || subscriptionHasAccess(resource.data.companyId)));
      allow create, update: if isGestor() && sameCompany(request.resource.data.companyId)
        && (isAdminEmail() || subscriptionCanWrite(request.resource.data.companyId));
      allow delete: if isAdmin();
    }

    // Contract templates (modelos personalizados por empresa)
    match /contractTemplates/{templateId} {
      allow read: if isDemo() || (isAuthenticated() && sameCompany(resource.data.companyId));
      allow create, update: if isGestor() && sameCompany(request.resource.data.companyId);
      allow delete: if isGestor() && sameCompany(resource.data.companyId);
    }

    // Owners
    match /owners/{ownerId} {
      allow read: if isDemo() || (isAuthenticated() && sameCompany(resource.data.companyId));
      allow write: if isGestor() && sameCompany(request.resource.data.companyId);
    }

    // Tenants
    match /tenants/{tenantId} {
      allow read: if isDemo()
        || (isAuthenticated() &&
          (sameCompany(resource.data.companyId) || request.auth.uid == tenantId));
      allow create, update: if isGestor();
      allow delete: if isAdmin();
    }

    // Contracts
    match /contracts/{contractId} {
      allow read: if isDemo()
        || (isAuthenticated() &&
          (sameCompany(resource.data.companyId) ||
           isLinkedTenant(resource.data.tenantId)));

      allow create: if isGestor();

      // Gestor/Admin: atualização completa.
      // Inquilino: pode apenas assinar o PRÓPRIO contrato — anexa sua assinatura,
      //   fotos e o PDF final, sem alterar termos, valores, status ou a parte do locador.
      allow update: if isGestor()
        || (isRole('inquilino')
            && request.auth.uid == resource.data.tenantId
            && request.resource.data.companyId  == resource.data.companyId
            && request.resource.data.tenantId    == resource.data.tenantId
            && request.resource.data.ownerId     == resource.data.ownerId
            && request.resource.data.propertyId  == resource.data.propertyId
            && request.resource.data.contractNumber == resource.data.contractNumber
            && request.resource.data.rentValue   == resource.data.rentValue
            && request.resource.data.startDate   == resource.data.startDate
            && request.resource.data.dueDay      == resource.data.dueDay
            && request.resource.data.status      == resource.data.status
            && request.resource.data.signatureLocador == resource.data.signatureLocador
            && request.resource.data.docsLocador == resource.data.docsLocador);

      allow delete: if isAdmin();
    }

    // Charges
    match /charges/{chargeId} {
      allow read: if isDemo()
        || (isAuthenticated() &&
          (sameCompany(resource.data.companyId) ||
           isLinkedTenant(resource.data.tenantId)));

      allow create: if isGestor();

      // Gestor/Admin: full update.
      // Inquilino: pode apenas anexar comprovante à própria cobrança
      //   — não pode alterar status, valor, vencimento nem confirmar o próprio pagamento.
      allow update: if isGestor()
        || (isLinkedTenant(resource.data.tenantId)
            && request.resource.data.status    == resource.data.status
            && request.resource.data.amount    == resource.data.amount
            && request.resource.data.dueDate   == resource.data.dueDate
            && request.resource.data.tenantId  == resource.data.tenantId
            && request.resource.data.companyId == resource.data.companyId
            && request.resource.data.receiptStatus == 'aguardando'
            && request.resource.data.paidBy == 'tenant');

      allow delete: if isAdmin();
    }

    // Payments
    match /payments/{paymentId} {
      allow read: if isDemo()
        || (isAuthenticated() &&
          (sameCompany(resource.data.companyId) ||
           isLinkedTenant(resource.data.tenantId)));
      allow create, update: if isGestor();
      allow delete: if isAdmin();
    }

    // Shared Expenses — membros da empresa leem; o client filtra participantes no portal do inquilino.
    match /sharedExpenses/{expenseId} {
      allow read: if isDemo() || (isAuthenticated() && sameCompany(resource.data.companyId));
      allow create: if isGestor();
      // Gestor: atualização completa.
      // Inquilino: pode anexar comprovante apenas na própria parcela (participants[i].receipt).
      allow update: if isGestor() || (
        userExists()
        && isRole('inquilino')
        && getUserData().companyId == resource.data.companyId
        && inquilinoIsSharedExpenseParticipant()
        && request.resource.data.companyId == resource.data.companyId
        && request.resource.data.propertyId == resource.data.propertyId
        && request.resource.data.totalAmount == resource.data.totalAmount
        && request.resource.data.description == resource.data.description
        && request.resource.data.type == resource.data.type
        && request.resource.data.status == resource.data.status
        && request.resource.data.participants.size() == resource.data.participants.size()
      );
      allow delete: if isAdmin();
    }

    // Maintenance Requests
    match /maintenanceRequests/{requestId} {
      allow read: if isDemo()
        || (isAuthenticated() &&
          (isLinkedTenant(resource.data.tenantId) ||
           (isProprietario() && sameCompany(resource.data.companyId))));

      allow create: if isAuthenticated() && (
        (isProprietario() && sameCompany(request.resource.data.companyId)) ||
        (isRole('inquilino')
          && userExists()
          && getUserData().tenantId == request.resource.data.tenantId
          && getUserData().companyId == request.resource.data.companyId
          && request.resource.data.status == 'aberto')
      );

      allow update: if (isProprietario() && sameCompany(resource.data.companyId)) ||
        (isLinkedTenant(resource.data.tenantId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['comments', 'updatedAt'])
          && request.resource.data.companyId == resource.data.companyId
          && request.resource.data.tenantId == resource.data.tenantId
          && request.resource.data.status == resource.data.status
          && request.resource.data.statusHistory == resource.data.statusHistory
          && request.resource.data.title == resource.data.title
          && request.resource.data.description == resource.data.description);
      allow delete: if isAdmin();
    }

    // Warnings (Advertências) — notificação formal do proprietário ao inquilino
    // por descumprimento contratual. Registro imutável (sem update), só delete
    // pelo admin em caso de engano.
    match /warnings/{warningId} {
      allow read: if isDemo()
        || (isAuthenticated() &&
          (isLinkedTenant(resource.data.tenantId) ||
           (isProprietario() && sameCompany(resource.data.companyId))));
      allow create: if isProprietario() && sameCompany(request.resource.data.companyId);
      allow update: if false;
      allow delete: if isAdmin();
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() &&
        (isGestor() || request.auth.uid == resource.data.recipientId);
      allow write: if isGestor();
    }

    // Audit Logs — G4: only gestors can create; clients cannot spam fake logs
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isGestor();
      allow update, delete: if false;
    }

    // Sistema Comercial (/sistema) — inbox interno de prospecção via WhatsApp.
    // Não é multi-empresa: só isAdmin()/isRole('comercial') entram, sem
    // depender do campo companyId do doc (que é só um valor fixo de
    // agrupamento, não uma empresa-cliente real).
    // Mensagens recebidas chegam via webhook com Admin SDK (ignora estas regras).
    match /salesConversations/{conversationId} {
      allow read, create, update: if isAuthenticated() && isComercial();
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read, create: if isAuthenticated() && isComercial();
        allow update, delete: if false;
      }
    }

    // Assinaturas de testemunhas (rota pública por token)
    // O token aleatório é o ID do documento e funciona como segredo do link.
    // Qualquer pessoa com o link pode LER (para ver a prévia) e ASSINAR uma vez,
    // sem poder alterar os dados do contrato nem reescrever uma assinatura já feita.
    match /witnessSignatures/{token} {
      allow get: if true;
      allow list: if isGestor();
      allow create: if isGestor() && sameCompany(request.resource.data.companyId);
      allow update: if isGestor()
        || (resource.data.status == 'pending'
            && request.resource.data.status == 'signed'
            && request.resource.data.contractId     == resource.data.contractId
            && request.resource.data.companyId       == resource.data.companyId
            && request.resource.data.contractNumber  == resource.data.contractNumber
            && request.resource.data.witnessName     == resource.data.witnessName
            && request.resource.data.witnessEmail    == resource.data.witnessEmail
            && request.resource.data.locadorName     == resource.data.locadorName
            && request.resource.data.locatarioName   == resource.data.locatarioName);
      allow delete: if isAdmin();
    }
  }
}
